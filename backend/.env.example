# ====== RAILWAY (isi di dashboard, bukan di file ini) ======
# Set variabel berikut di service backend Railway, menunjuk ke service MySQL:
#   DB_HOST      = ${{ MySQL.MYSQLHOST }}
#   DB_PORT      = ${{ MySQL.MYSQLPORT }}
#   DB_USER      = ${{ MySQL.MYSQLUSER }}
#   DB_PASSWORD  = ${{ MySQL.MYSQLPASSWORD }}
#   DB_NAME      = ${{ MySQL.MYSQLDATABASE }}
#   JWT_SECRET   = (buat string acak panjang)
# PORT tidak perlu diisi — Railway mengaturnya otomatis.
